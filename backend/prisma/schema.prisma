generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  full_name     String?
  birthday      DateTime?
  address       String?
  avatar_url    String?
  education     String?  
  current_level String?   // e.g. "Student", "Junior"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  skills      UserSkill[]
  experiences UserExperience[]
  feedbacks   Feedback[]
  interests   UserInterest[]
  trajectories Trajectory[]
  savedPaths   SavedPath[]
}

model UserSkill {
  id            String      @id @default(uuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerSkillId String
  careerSkill   CareerSkill @relation(fields: [careerSkillId], references: [id], onDelete: Cascade)

  @@unique([userId, careerSkillId])
}

model UserInterest {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerInterestId String
  careerInterest   CareerInterest @relation(fields: [careerInterestId], references: [id], onDelete: Cascade)

  @@unique([userId, careerInterestId])
}

model UserExperience {
  id       String @id @default(uuid())
  title    String
  duration Int    // in months
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Career {
  id          String   @id @default(uuid())
  title       String
  description String
  domain      String
  category    String   @default("General")

  skills    CareerSkill[]
  levels    CareerLevel[]
  feedback  Feedback[]
  interests CareerInterest[]
  trajectories Trajectory[]
  savedPaths   SavedPath[]
  milestones   Milestone[]
}

model CareerSkill {
  id          String  @id @default(uuid())
  skill_name  String
  is_required Boolean @default(true)
  category    String  @default("Technical")
  careerId    String
  career      Career  @relation(fields: [careerId], references: [id], onDelete: Cascade)
  userSkills  UserSkill[]
}

model CareerLevel {
  id                        String @id @default(uuid())
  level_name                String // "Intern", "Junior", "Mid", "Senior"
  required_experience_years Int
  careerId                  String
  career                    Career @relation(fields: [careerId], references: [id], onDelete: Cascade)
}

model Feedback {
  id         String   @id @default(uuid())
  userId     String
  careerId   String
  isRelevant Boolean
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  career Career @relation(fields: [careerId], references: [id], onDelete: Cascade)
}

model CareerInterest {
  id            String   @id @default(uuid())
  interest_name String
  category      String   @default("General")
  careerId      String
  career        Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)
  userInterests UserInterest[]
}

model Trajectory {
  id           String   @id @default(uuid())
  userId       String
  careerId     String
  careerTitle  String
  score        Float
  level        String
  explanation  String   @db.Text
  createdAt    DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  career Career @relation(fields: [careerId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SavedPath {
  id        String   @id @default(uuid())
  userId    String
  careerId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  career Career @relation(fields: [careerId], references: [id], onDelete: Cascade)

  @@unique([userId, careerId])
}

model Milestone {
  id          String @id @default(uuid())
  careerId    String
  title       String
  description String @db.Text
  order       Int

  career Career @relation(fields: [careerId], references: [id], onDelete: Cascade)
}
